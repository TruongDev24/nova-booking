generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
  COURT_MANAGER
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

enum PaymentStatus {
  UNPAID
  PARTIAL_PAID
  PAID
  REFUNDED
}

enum PaymentMethod {
  CASH
  BANK_TRANSFER
  E_WALLET
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  fullName  String
  phone     String
  avatar    String?
  role      Role     @default(USER)
  createdAt DateTime @default(now()) @db.Timestamptz(3)
  updatedAt DateTime @updatedAt @db.Timestamptz(3)

  bookings Booking[]
  payments Payment[]
  reviews  Review[]
  courts   Court[]
}

model Court {
  id           String   @id @default(uuid())
  name         String
  location     String
  description  String
  pricePerHour Float
  openingTime  String
  closingTime  String
  amenities    String[]
  images       String[]
  ownerId      String
  isDeleted    Boolean  @default(false)
  createdAt    DateTime @default(now()) @db.Timestamptz(3)
  updatedAt    DateTime @updatedAt @db.Timestamptz(3)

  owner    User      @relation(fields: [ownerId], references: [id])
  bookings Booking[]
  reviews  Review[]
}

model Booking {
  id            String        @id @default(uuid())
  userId        String
  courtId       String
  bookingDate   String        // Định dạng YYYY-MM-DD
  startTime     String        // Định dạng HH:mm
  endTime       String        // Định dạng HH:mm
  totalPrice    Float
  status        BookingStatus @default(PENDING)
  paymentStatus PaymentStatus @default(UNPAID)
  cancelReason  String?
  createdAt     DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime      @updatedAt @db.Timestamptz(3)

  user    User     @relation(fields: [userId], references: [id])
  court   Court    @relation(fields: [courtId], references: [id])
  payment Payment?

  @@unique([courtId, bookingDate, startTime])
  @@index([bookingDate])
  @@index([courtId, status])
}

model Payment {
  id            String        @id @default(uuid())
  bookingId     String        @unique
  userId        String
  amount        Float
  method        PaymentMethod
  transactionId String?
  status        PaymentStatus
  createdAt     DateTime      @default(now()) @db.Timestamptz(3)
  updatedAt     DateTime      @updatedAt @db.Timestamptz(3)

  user    User    @relation(fields: [userId], references: [id])
  booking Booking @relation(fields: [bookingId], references: [id])

  @@index([bookingId])
  @@index([userId, status])
}

model Review {
  id        String   @id @default(uuid())
  userId    String
  courtId   String
  rating    Int
  comment   String
  createdAt DateTime @default(now()) @db.Timestamptz(3)

  user  User  @relation(fields: [userId], references: [id])
  court Court @relation(fields: [courtId], references: [id])

  @@index([courtId])
}
